# Bot Environment
BOT_TOKEN="<your-bot-token>"
LOCAL_BOT_API_URL="http://127.0.0.1:8081"
BOT_API_DIR="./bot-api/"   # Directory path where the local Telegram Bot API files are stored
DOWNLOAD_TO_DIR="./downloads/"
USER_ID=1234567890         # Change to your user ID
CHAT_ID=1234567890         # Change to your user ID (DM with bot) or a group ID
APP_SETTINGS_FILE="./data/settings.json"
SINGLE_FILE_GROUP_ENABLED=False
SINGLE_FILE_GROUP_DELAY=1.0
DOWNLOAD_STATUS_UPDATE_INTERVAL=5.0
MAX_CONCURRENT_DOWNLOADS=1
TELEGRAM_DOWNLOADER_VERSION=0.2.1
TELEGRAM_BOT_API_VERSION=10.1.0

# Local API Environment
TELEGRAM_API_ID=<your-telegram-api-id>
TELEGRAM_API_HASH="<your-telegram-api-hash>"
TELEGRAM_LOCAL=True

# API image build
TELEGRAM_BOT_API_REPOSITORY="https://github.com/Dedrimer/telegram-bot-api.git"
TELEGRAM_BOT_API_REF="master"
TELEGRAM_BOT_API_BUILD_JOBS=2
